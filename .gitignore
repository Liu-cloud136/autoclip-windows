# Node.js
# ========================================

# Dependencies
node_modules/
jspm_packages/

# Build outputs
dist/
build/
.next/
out/
.nuxt/
.cache/
.vuepress/dist/
.serverless/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Testing
coverage/
.nyc_output

# ========================================
# IDE and Editors
# ========================================

# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm)
