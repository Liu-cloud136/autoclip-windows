# ========================================
# Project Specific
# ========================================

# Database files
*.db
*.db-journal
*.sqlite
*.sqlite3

# Data directory (auto-generated on runtime)
data/

# Output directory (auto-generated on runtime)
output/

# Log files (auto-generated on runtime)
logs/
*.log

